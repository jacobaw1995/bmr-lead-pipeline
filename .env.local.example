# Supabase — create a project at https://supabase.com and run brothers_metal_roofing_schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook authentication — generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret